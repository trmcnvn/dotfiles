{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "theme": "system",
  "enabled_providers": [
    "opencode",
    "openai"
  ],
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "secrets/*": "deny",
      "~/.local/share/opencode/mcp-auth.json": "deny"
    }
  },
  "keybinds": {
    "leader": "ctrl+o",
    "variant_cycle": "<leader>t"
  },
  "plugin": [
    "@sveltejs/opencode"
  ],
  "mcp": {
    "pg-aiguide": {
      "type": "remote",
      "url": "https://mcp.tigerdata.com/docs",
      "enabled": false
    },
    "cloudflare": {
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp",
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "opensrc": {
      "type": "local",
      "command": [
        "bunx",
        "opensrc-mcp"
      ],
      "enabled": true
    },
    "metafy-api": {
      "type": "remote",
      "url": "https://dev.metafy.gg/mcp",
      "enabled": false
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "enabled": false
    }
  }
}
