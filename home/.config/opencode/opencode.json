{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "theme": "rosepine",
  "enabled_providers": [
    "opencode",
    "openai"
  ],
  "provider": {
    "openai": {
      "models": {
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "tool_call": true,
          "reasoning": true,
          "temperature": true,
          "attachment": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "limit": {
            "context": 1047676,
            "output": 65536
          },
          "options": {
            "store": false
          }
        }
      }
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.envrc": "deny",
      "secrets/*": "deny"
    }
  },
  "keybinds": {
    "leader": "ctrl+o",
    "variant_cycle": "<leader>t",
  },
  "plugin": [
    "@sveltejs/opencode"
  ],
  "mcp": {
    "pg-aiguide": {
      "type": "remote",
      "url": "https://mcp.tigerdata.com/docs",
      "enabled": false
    },
    "whop": {
      "type": "remote",
      "url": "https://docs.whop.com/mcp",
      "enabled": false
    },
    "cloudflare-docs": {
      "type": "remote",
      "url": "https://docs.mcp.cloudflare.com/mcp",
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "opensrc": {
      "type": "local",
      "command": [
        "bunx",
        "opensrc-mcp"
      ],
      "enabled": true
    },
    "metafy-api": {
      "type": "remote",
      "url": "https://dev.metafy.gg/mcp",
      "enabled": false
    }
  }
}
