# Font
font-family = TX-02
font-style = Condensed
font-style-italic = Condensed Oblique
font-style-bold = Bold Condensed
font-style-bold-italic = Bold Condensed Oblique
font-size = 10

# General font settings
font-thicken = true
font-synthetic-style = false

# Cursor
cursor-style = block
cursor-style-blink = false
mouse-hide-while-typing = true

# Window
window-inherit-font-size = true
window-save-state = never
window-padding-color = background
window-padding-balance = true
window-padding-x = 0
window-padding-y = 0
window-colorspace = display-p3
macos-option-as-alt = true
macos-window-shadow = false
macos-titlebar-proxy-icon = hidden
macos-titlebar-style = tabs
window-theme = ghostty
window-decoration = true
title = Ghostty 👻

# Functionality
command = bash -l -c nu
shell-integration = none
shell-integration-features = no-cursor,sudo,title,ssh-env,ssh-terminfo
clipboard-read = allow
clipboard-write = allow
clipboard-paste-protection = false
quit-after-last-window-closed = false
confirm-close-surface = true
resize-overlay = never
scrollback-limit = 100_000_000

# Theme
theme = solarized_osaka_dark
background = #001419
macos-icon = official
background-opacity = 1
background-blur = false
background-opacity-cells = true
unfocused-split-opacity = 0.95

# Keybinds
keybind = opt+enter=new_split:right
keybind = opt+ctrl+enter=new_split:down
keybind = performable:ctrl+c=copy_to_clipboard
keybind = ctrl+v=paste_from_clipboard
keybind = ctrl+t=new_tab
keybind = ctrl+1=goto_tab:1
keybind = ctrl+2=goto_tab:2
keybind = ctrl+3=goto_tab:3
keybind = ctrl+4=goto_tab:4
keybind = ctrl+5=goto_tab:5
keybind = ctrl+tab=next_tab
keybind = ctrl+shift+tab=previous_tab
keybind = alt+backspace=text:\x1b\x7f
