// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "vim_mode != insert && !Terminal",
    "bindings": {
      "tab": "pane::ActivateNextItem",
      "shift-tab": "pane::ActivatePreviousItem",
    },
  },
  {
    "context": "vim_mode != insert",
    "bindings": {
      "ctrl-w": "pane::CloseActiveItem",
      "ctrl-left": "workspace::ActivatePaneLeft",
      "ctrl-right": "workspace::ActivatePaneRight",
      "ctrl-up": "workspace::ActivatePaneUp",
      "ctrl-down": "workspace::ActivatePaneDown",
      "ctrl-e": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "Editor && (vim_mode == insert || vim_mode == visual) && !menu",
    "bindings": {
      "ctrl-c": "editor::Copy",
      "ctrl-v": "editor::Paste",
      "ctrl-x": "editor::Cut",
      "ctrl-a": "editor::SelectAll",
    },
  },
  {
    "context": "Terminal && !menu",
    "bindings": {
      "ctrl-v": "terminal::Paste",
      "ctrl-t": "workspace::NewTerminal",
      "ctrl-1": ["pane::ActivateItem", 0],
      "ctrl-2": ["pane::ActivateItem", 1],
      "ctrl-3": ["pane::ActivateItem", 2],
      "ctrl-4": ["pane::ActivateItem", 3],
    },
  },
]
