{
  "servers": {
    "pg-aiguide": {
      "type": "remote",
      "url": "https://mcp.tigerdata.com/docs",
      "enabled": false
    },
    "cloudflare": {
      "type": "remote",
      "url": "https://mcp.cloudflare.com/mcp",
      "enabled": false
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "opensrc": {
      "type": "local",
      "command": "bunx",
      "args": [
        "opensrc-mcp"
      ],
      "enabled": true,
      "outputMode": "muted"
    },
    "svelte": {
      "type": "remote",
      "url": "https://mcp.svelte.dev/mcp",
      "enabled": true
    },
    "metafy-api": {
      "type": "remote",
      "url": "https://dev.metafy.gg/mcp",
      "enabled": false
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "enabled": false
    },
    "computer-use": {
      "type": "local",
      "command": "/home/trmcnvn/.local/bin/pi-mcp-computer-use",
      "args": [
        "--split",
        "--images-as-files"
      ],
      "cwd": "/home/trmcnvn/Code/mcp-computer-use",
      "enabled": true,
      "outputMode": "full"
    }
  }
}
